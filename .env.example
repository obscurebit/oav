# NVIDIA NIM API (OpenAI-compatible)
VITE_LLM_API_KEY=your-nvidia-api-key-here
VITE_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# Director model (engine control — tool calling)
VITE_LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# Poet model (display text — poetic words only, no tools)
VITE_POET_MODEL=meta/llama-4-scout-17b-16e-instruct
